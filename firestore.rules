rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: userId
    // Fields:
    //   - displayName: string (required)
    //   - email: string (required)
    //   - createdAt: string (required)
    //
    // Collection: scores
    // Document ID: scoreId
    // Fields:
    //   - title: string (required, < 100 chars)
    //   - composer: string (optional, < 100 chars)
    //   - instrument: string (required, < 50 chars)
    //   - description: string (optional, < 1000 chars)
    //   - uploaderId: string (required, must match auth.uid)
    //   - uploaderName: string (required, < 50 chars)
    //   - isPublic: boolean (required)
    //   - downloads: number (required, >= 0)
    //   - createdAt: string (required)
    //
    // Collection: scoreFiles
    // Document ID: scoreId (must match a document in scores)
    // Fields:
    //   - content: string (required, < 1000000 chars)
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isValidString(val, minLen, maxLen) {
      return val is string && val.size() >= minLen && val.size() <= maxLen;
    }

    function isValidOptionalString(val, maxLen) {
      return val == null || (val is string && val.size() <= maxLen);
    }

    // Users Collection
    match /users/{userId} {
      allow read: if isAuthenticated(); // Allow users to read profiles (e.g., uploader info)
      allow create: if isOwner(userId)
                    && request.resource.data.keys().hasAll(['displayName', 'email', 'createdAt'])
                    && isValidString(request.resource.data.displayName, 1, 50)
                    && isValidString(request.resource.data.email, 5, 100);
      allow update: if isOwner(userId)
                    && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['displayName'])
                    && isValidString(request.resource.data.displayName, 1, 50);
    }

    // Scores Collection
    match /scores/{scoreId} {
      // Anyone can read public scores, owner can read their own private scores
      allow read: if resource.data.isPublic == true || (isAuthenticated() && resource.data.uploaderId == request.auth.uid);
      
      allow create: if isAuthenticated()
                    && request.resource.data.keys().hasAll(['title', 'instrument', 'uploaderId', 'uploaderName', 'isPublic', 'downloads', 'createdAt'])
                    && isValidString(request.resource.data.title, 1, 100)
                    && isValidString(request.resource.data.instrument, 1, 50)
                    && request.resource.data.uploaderId == request.auth.uid
                    && isValidString(request.resource.data.uploaderName, 1, 50)
                    && request.resource.data.isPublic is bool
                    && request.resource.data.downloads == 0
                    && isValidOptionalString(request.resource.data.get('composer', ''), 100)
                    && isValidOptionalString(request.resource.data.get('description', ''), 1000);
                    
      allow update: if isAuthenticated()
                    && (
                      // Owner can update metadata
                      (resource.data.uploaderId == request.auth.uid
                       && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['title', 'composer', 'instrument', 'description', 'isPublic'])
                       && isValidString(request.resource.data.title, 1, 100)
                       && isValidString(request.resource.data.instrument, 1, 50)
                       && isValidOptionalString(request.resource.data.get('composer', ''), 100)
                       && isValidOptionalString(request.resource.data.get('description', ''), 1000)
                       && request.resource.data.isPublic is bool)
                      ||
                      // Anyone can increment downloads
                      (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['downloads'])
                       && request.resource.data.downloads == resource.data.downloads + 1)
                    );
                    
      allow delete: if isAuthenticated() && resource.data.uploaderId == request.auth.uid;
    }

    // Score Files Collection
    match /scoreFiles/{scoreId} {
      // Read allowed if the corresponding score is public or owned by the user
      allow read: if get(/databases/$(database)/documents/scores/$(scoreId)).data.isPublic == true 
                  || (isAuthenticated() && get(/databases/$(database)/documents/scores/$(scoreId)).data.uploaderId == request.auth.uid);
                  
      allow create: if isAuthenticated()
                    && request.resource.data.keys().hasAll(['content'])
                    && isValidString(request.resource.data.content, 1, 1000000) // Up to ~1MB MusicXML
                    && getAfter(/databases/$(database)/documents/scores/$(scoreId)).data.uploaderId == request.auth.uid;
                    
      allow update: if isAuthenticated()
                    && get(/databases/$(database)/documents/scores/$(scoreId)).data.uploaderId == request.auth.uid
                    && request.resource.data.keys().hasAll(['content'])
                    && isValidString(request.resource.data.content, 1, 1000000);
                    
      allow delete: if isAuthenticated() && get(/databases/$(database)/documents/scores/$(scoreId)).data.uploaderId == request.auth.uid;
    }
  }
}
