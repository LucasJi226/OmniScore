{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the OmniScore platform",
      "type": "object",
      "properties": {
        "displayName": { "type": "string" },
        "email": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["displayName", "email", "createdAt"]
    },
    "Score": {
      "title": "Score Metadata",
      "description": "Metadata for a sheet music file",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "composer": { "type": "string" },
        "instrument": { "type": "string" },
        "description": { "type": "string" },
        "uploaderId": { "type": "string" },
        "uploaderName": { "type": "string" },
        "isPublic": { "type": "boolean" },
        "downloads": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "instrument", "uploaderId", "uploaderName", "isPublic", "downloads", "createdAt"]
    },
    "ScoreFile": {
      "title": "Score File Content",
      "description": "The actual MusicXML content of the score",
      "type": "object",
      "properties": {
        "content": { "type": "string" }
      },
      "required": ["content"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "User profiles"
    },
    "/scores/{scoreId}": {
      "schema": { "$ref": "#/entities/Score" },
      "description": "Metadata for scores available in the market or private library"
    },
    "/scoreFiles/{scoreId}": {
      "schema": { "$ref": "#/entities/ScoreFile" },
      "description": "The MusicXML content for a score, separated to avoid large document reads when listing"
    }
  }
}
